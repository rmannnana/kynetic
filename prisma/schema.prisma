generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int      @id @default(autoincrement())
  email            String?  @unique
  phone            String?  @unique
  countryPhoneCode String?
  password         String?
  name             String?
  createdAt        DateTime @default(now())
}
